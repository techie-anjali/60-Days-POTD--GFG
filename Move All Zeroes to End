class Solution {
    void pushZerosToEnd(int[] arr) {
        int i=0;
        int j=0;
        int temp=0;
        int n=arr.length;
        for(i=0;i<n;i++){
           
                if(arr[i]!=0){
                    temp=arr[i];
                    arr[i]=arr[j];
                    arr[j]=temp;
                      j++;
                    
                }
              
            }
            
        }
        
    }
